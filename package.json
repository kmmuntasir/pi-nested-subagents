{
  "name": "@kmmuntasir/pi-nested-subagents",
  "version": "0.1.0",
  "description": "A pi extension that brings Claude Code-style autonomous sub-agents to pi, with safe configurable nesting depth and built-in ground-truth verification. Fork of tintinweb/pi-subagents.",
  "author": "kmmuntasir",
  "contributors": [
    "tintinweb (upstream pi-subagents)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kmmuntasir/pi-nested-subagents.git"
  },
  "homepage": "https://github.com/kmmuntasir/pi-nested-subagents#readme",
  "bugs": {
    "url": "https://github.com/kmmuntasir/pi-nested-subagents/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "subagent",
    "agent",
    "autonomous",
    "nested",
    "nesting",
    "verification"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.74.0",
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@earendil-works/pi-tui": ">=0.74.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "croner": "^10.0.1",
    "nanoid": "^5.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run e2e --reporter=verbose",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --fix src/ test/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
